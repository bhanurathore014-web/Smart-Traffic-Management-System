# ==============================================================
# Environment Variables — Smart Traffic Management System
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO GIT
# ==============================================================

# --------------------------------------------------------------
# Application
# --------------------------------------------------------------
APP_NAME="Smart Traffic Management System"
APP_VERSION="1.0.0"
APP_ENV="development"           # development | production
DEBUG=true
SECRET_KEY="change-this-to-a-random-secret-key-in-production"

# --------------------------------------------------------------
# Database
# Development: SQLite (auto-created)
# Production:  PostgreSQL
# --------------------------------------------------------------
DATABASE_URL="sqlite+aiosqlite:///./database/smart_traffic_dev.db"
# DATABASE_URL="postgresql+asyncpg://traffic_user:password@localhost:5432/smart_traffic"

# For Alembic migrations (sync driver)
ALEMBIC_DATABASE_URL="sqlite:///./database/smart_traffic_dev.db"
# ALEMBIC_DATABASE_URL="postgresql://traffic_user:password@localhost:5432/smart_traffic"

# --------------------------------------------------------------
# API Server
# --------------------------------------------------------------
API_HOST="0.0.0.0"
API_PORT=8000
API_RELOAD=true                 # Hot reload (dev only)
API_WORKERS=1                   # Increase for production

# --------------------------------------------------------------
# Streamlit Dashboard
# --------------------------------------------------------------
DASHBOARD_PORT=8501
DASHBOARD_REFRESH_INTERVAL=2    # seconds

# --------------------------------------------------------------
# YOLOv8 Detection
# --------------------------------------------------------------
YOLO_MODEL_SIZE="s"             # n | s | m | l | x
YOLO_MODEL_PATH="models/weights/yolov8s.pt"
YOLO_CONF_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE="auto"              # auto | cpu | cuda | mps

# --------------------------------------------------------------
# ByteTrack Configuration
# --------------------------------------------------------------
TRACKER_TRACK_THRESH=0.5
TRACKER_TRACK_BUFFER=30         # Max frames to keep lost track
TRACKER_MATCH_THRESH=0.8
TRACKER_FRAME_RATE=25

# --------------------------------------------------------------
# Traffic Signal Configuration
# --------------------------------------------------------------
SIGNAL_MIN_GREEN=10             # seconds
SIGNAL_MAX_GREEN=90             # seconds
SIGNAL_YELLOW_TIME=3            # seconds
SIGNAL_TOTAL_CYCLE=150          # seconds
SIGNAL_NUM_LANES=4

# --------------------------------------------------------------
# Emergency Detection
# --------------------------------------------------------------
EMERGENCY_CONF_THRESHOLD=0.60
EMERGENCY_CONFIRM_FRAMES=3      # consecutive frames for confirmation
EMERGENCY_CLASSES="ambulance,fire truck,police car"

# --------------------------------------------------------------
# ANPR (Number Plate Recognition)
# --------------------------------------------------------------
ANPR_MIN_CONFIDENCE=0.50
ANPR_OCR_PRIMARY="easyocr"      # easyocr | paddleocr
ANPR_LANGUAGES="en"
ANPR_SAVE_IMAGES=true           # save plate crop images
ANPR_IMAGE_DIR="outputs/plates"

# --------------------------------------------------------------
# Traffic Density
# --------------------------------------------------------------
DENSITY_WEIGHT_COUNT=0.5        # weight for vehicle count
DENSITY_WEIGHT_OCCUPANCY=0.3    # weight for lane occupancy
DENSITY_WEIGHT_SPEED=0.2        # weight for inverse speed
DENSITY_SMOOTH_WINDOW=5         # seconds for time-averaging
DENSITY_LOW_THRESHOLD=0.25
DENSITY_MEDIUM_THRESHOLD=0.50
DENSITY_HIGH_THRESHOLD=0.75

# --------------------------------------------------------------
# Video Processing
# --------------------------------------------------------------
VIDEO_SOURCE="videos/sample_traffic.mp4"  # file path or RTSP URL
VIDEO_RESIZE_WIDTH=1280
VIDEO_RESIZE_HEIGHT=720
VIDEO_FRAME_SKIP=0              # 0=process every frame; 1=skip 1 frame
VIDEO_OUTPUT_DIR="outputs/frames"
VIDEO_SAVE_OUTPUT=false         # save annotated output video

# Lane ROI (Region of Interest) — x1,y1,x2,y2 as fraction of frame
LANE_1_ROI="0.0,0.0,0.25,1.0"
LANE_2_ROI="0.25,0.0,0.50,1.0"
LANE_3_ROI="0.50,0.0,0.75,1.0"
LANE_4_ROI="0.75,0.0,1.0,1.0"

# Counting line position (y-coordinate as fraction of frame height)
COUNTING_LINE_Y=0.6

# --------------------------------------------------------------
# Logging
# --------------------------------------------------------------
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR
LOG_DIR="logs"
LOG_FILE="smart_traffic.log"
LOG_ROTATION="1 day"
LOG_RETENTION="30 days"

# --------------------------------------------------------------
# Analytics
# --------------------------------------------------------------
ANALYTICS_AGGREGATE_INTERVAL=3600  # seconds (1 hour)
ANALYTICS_RETENTION_DAYS=90
